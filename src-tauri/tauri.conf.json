{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Tutor",
  "version": "0.3.0",
  "identifier": "com.augmentifai.personal-tutor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3017",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Personal Tutor",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {}
}
